{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "video-player-fit-demo",
  "type": "registry:example",
  "title": "Video Player Fit",
  "description": "A video player demo showing fit behavior",
  "files": [
    {
      "path": "registry/8starlabs-ui/examples/video-player-fit-demo.tsx",
      "content": "import VideoRoot, {\n  VideoViewport,\n  VideoControls,\n  VideoPlayTrigger,\n  VideoProgressBar,\n  VideoFullscreenTrigger\n} from \"@/registry/8starlabs-ui/blocks/video-player\";\n\nexport default function VideoPlayerFitDemo() {\n  return (\n    <div className=\"grid w-full gap-6 md:grid-cols-2 m-4\">\n      <div className=\"space-y-2\">\n        <p className=\"text-center text-xs font-medium uppercase tracking-wider text-muted-foreground\">\n          fit: cover\n        </p>\n        <VideoRoot className=\"aspect-square rounded-lg\">\n          <VideoViewport src=\"/sample_scenery.mp4\" fit=\"cover\" />\n          <VideoControls className=\"flex items-center justify-between gap-4\">\n            <VideoPlayTrigger />\n            <VideoProgressBar />\n            <VideoFullscreenTrigger />\n          </VideoControls>\n        </VideoRoot>\n      </div>\n\n      <div className=\"space-y-2\">\n        <p className=\"text-center text-xs font-medium uppercase tracking-wider text-muted-foreground\">\n          fit: contain\n        </p>\n        <VideoRoot className=\"aspect-square rounded-lg\">\n          <VideoViewport src=\"/sample_scenery.mp4\" fit=\"contain\" />\n          <VideoControls className=\"flex items-center justify-between gap-4\">\n            <VideoPlayTrigger />\n            <VideoProgressBar />\n            <VideoFullscreenTrigger />\n          </VideoControls>\n        </VideoRoot>\n      </div>\n    </div>\n  );\n}\n",
      "type": "registry:example",
      "target": "components/8starlabs-ui/examples/video-player-fit-demo.tsx"
    }
  ]
}
